                                "api",
                                "auth",
                                "test-encrypt"
                            ],
                            "query": [
                                {
                                    "key": "password",
                                    "value": "test"
                                }
                            ]
                        },
                        "description": "Test AES encryption"
                    }
                },
                {
                    "name": "Test Decrypt AES",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/auth/test-decrypt?password=encrypted-data",
                            "host": [
                                "{{base_url}}"
