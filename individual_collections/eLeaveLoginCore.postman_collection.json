        {
            "name": "Encryption",
            "item": [
                {
                    "name": "Test Encrypt SHA256",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"password\": \"test\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/test-encrypt-sha256",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "test-encrypt-sha256"
                            ]
                        },
                        "description": "Test SHA256 encryption",
                        "preRequestScript": "var CryptoJS = require('crypto-js');\n\n// Generate a random password for testing if not provided\nif (!pm.environment.get('test_password')) {\n    pm.environment.set('test_password', 'test' + Math.floor(Math.random() * 10000));\n}",
                        "script": {
                            "id": "sha256-encrypt-script",
                            "exec": [
                                "if (pm.response.successful) {",
                                "    var response = pm.response.json();",
                                "    pm.environment.set('sha256_encrypted', response.encrypted);",
                                "    console.log('SHA256 Encrypted:', response.encrypted);",
                                "}"
                            ],
                            "type": "text"
                        }
                    }
                },
                {
                    "name": "Test Verify SHA256",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"password\": \"test\",\n    \"encrypted\": \"{{sha256_encrypted}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/test-verify-sha256",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "test-verify-sha256"
                            ]
                        },
                        "description": "Test SHA256 verification",
                        "preRequestScript": "// Use the previously encrypted value from environment variable\nvar encrypted = pm.environment.get('sha256_encrypted');",
                        "script": {
                            "id": "sha256-verify-script",
                            "exec": [
                                "if (pm.response.successful) {",
                                "    var response = pm.response.json();",
                                "    pm.test('SHA256 verification should be true', function () {",
                                "        pm.expect(response.verified).to.equal(true);",
                                "    });",
                                "}"
                            ],
                            "type": "text"
                        }
                    }
                },
                {
                    "name": "Test Encrypt AES",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"password\": \"test\",\n    \"key\": \"secret key 122\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/test-encrypt",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "test-encrypt"
                            ]
                        },
                        "description": "Test AES encryption",
                        "preRequestScript": "// Set default key if not provided\nif (!pm.environment.get('aes_key')) {\n    pm.environment.set('aes_key', 'secret key 122');\n}",
                        "script": {
                            "id": "aes-encrypt-script",
                            "exec": [
                                "if (pm.response.successful) {",
                                "    var response = pm.response.json();",
                                "    pm.environment.set('aes_encrypted', response.encrypted);",
                                "    console.log('AES Encrypted:', response.encrypted);",
                                "}"
                            ],
                            "type": "text"
                        }
                    }
                },
                {
                    "name": "Test Decrypt AES",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"encrypted\": \"{{aes_encrypted}}\",\n    \"key\": \"{{aes_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/test-decrypt",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "test-decrypt"
                            ]
                        },
                        "description": "Test AES decryption",
                        "preRequestScript": "// Use the previously encrypted value and key from environment variables\nvar encrypted = pm.environment.get('aes_encrypted');\nvar key = pm.environment.get('aes_key');",
                        "script": {
                            "id": "aes-decrypt-script",
                            "exec": [
                                "if (pm.response.successful) {",
                                "    var response = pm.response.json();",
                                "    pm.environment.set('aes_decrypted', response.decrypted);",
                                "    pm.test('AES decryption should match original', function () {",
                                "        pm.expect(response.decrypted).to.equal('test');",
                                "    });",
                                "}"
                            ],
                            "type": "text"
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3003",
            "type": "string"
        },
        {
            "key": "access_token",
            "value": "",
            "type": "string"
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "id": "collection-prerequest-script",
                "type": "text",
                "exec": [
                    "// Collection-level pre-request script",
                    "// Initialize environment variables if not set",
                    "if (!pm.environment.get('base_url')) {",
                    "    pm.environment.set('base_url', 'http://localhost:3003');",
                    "}",
                    "if (!pm.environment.get('aes_key')) {",
                    "    pm.environment.set('aes_key', 'secret key 122');",
                    "}"
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "id": "collection-test-script",
                "type": "text",
                "exec": [
                    "// Collection-level test script",
                    "// Log response time for all requests",
                    "pm.test('Response time is reasonable', function () {",
                    "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                    "});"
                ]
            }
        }
    ]
